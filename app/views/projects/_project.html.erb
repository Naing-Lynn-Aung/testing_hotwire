<%= turbo_frame_tag dom_id(project) do %>
  <div class="card card-custom card-custom--shadow mt-3">
    <div class="card-header d-flex justify-content-between align-items-center px-3 py-0">
      <h5 class="mt-3">Draft</h5>
      <%= button_to "Vote #{project.vote}", project_votes_path(project), method: :post, class: "btn btn-sm btn-primary" %>
    </div>
    <div class="card-body">
      <div class="d-flex justify-content-between">
        <h5 class="card-title"> <%= link_to highlight("#{project.title}", highlight_query), project_path(project), class: "nav-link", data: { turbo: false } %> </h5>
      </div>
      <p class="card-text">
        <%= highlight(project.content.truncate(100), highlight_query) %>
      </p>
      <div class="d-flex justify-content-between">
        Start From <%= project.start.to_fs(:rfc822) %> to <%= project.end.to_fs(:rfc822) %>
      </div>
      <div class="d-flex justify-content-between">
        <small>
          <%= button_to 'Delete', project, method: :delete, form: { data: { turbo_confirm: "Are you sure?" } }, class: "btn btn-sm btn-danger" %>
        </small>
        <%= link_to 'Edit', edit_project_path(project) %>
      </div>
    </div>
  </div>
<% end %>
