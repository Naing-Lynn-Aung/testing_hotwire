<%= turbo_stream.remove dom_id(@project) %>

<%= turbo_stream.update "project_form" do %>
  <% if @projects.none? %>
    <div class="empty m-4">
      <p class="empty-text">you don't have any project.</p>
      <%= link_to "Create New Project", new_project_path, class: "btn btn-primary text-white", data: { turbo_frame: "project_form" } %>
    </div>
  <% else %>
    <%= link_to "New Project", new_project_path, class: "btn btn-primary text-white", data: { turbo_frame: "project_form" } %>
  <% end %>
<% end %>

<%= turbo_stream.replace "projects" do %>
  <%= turbo_frame_tag "projects" do %>
    <%= render @projects %>
  <% end %>
<% end %>