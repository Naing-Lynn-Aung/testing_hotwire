<%= turbo_stream_from "projects" %>
<div class="d-flex justify-content-end mb-2">
    <%= link_to "New Project", new_project_path, class: "btn btn-primary text-white", data: { turbo_frame: "project_form" } %>
</div>
<nav class="navbar bg-light">
    <div class="container-fluid">
        <form class="d-flex col-12" role="search">
            <input type="search" class="form-control" placeholder="search" aria-label="search">
        </form>
    </div>
</nav>
<%= turbo_frame_tag Project.new %>
<%= turbo_frame_tag "project_form" do %>
    <% if @projects.none? %>
        <%= render "empty_state" %>
    <% end %>
    <%= render @projects %>
<% end %>