<div class="mt-2">
  <%= simple_form_for project, html: { id: dom_id(project), class: "card-custom--project card-custom--shadow" } do |form| %>
    <div class="row">
      <%= form.input :title %>
      <%= form.input :content, as: :text %>
    </div>
    <div class="d-flex justify-content-between">
      <%= form.input :start, as: :date, start_year: Date.current.year, order: [:day, :month, :year] %>
      <%= form.input :end, as: :date, start_year: Date.current.year, order: [:day, :month, :year] %>
    </div>
    
    <div class="d-flex justify-content-between mt-2">
      <%= link_to sanitize("back"), projects_path, class: "mt-2" %>
      <%= form.button :submit %>
    </div>
  <% end  %>
</div>
