<%= turbo_frame_tag dom_id(task) do %>
    <div class="card card-body my-3">
      <div class="d-flex justify-content-between">
        <%= task.body %>
        <small><%= task.status %></small>
      </div>
      <div class="d-flex justify-content-between">
        <small>
            <%= time_ago_in_words(task.created_at) %>
            <%= button_to 'Delete', project_task_path(task.project, task), method: :delete, form: { data: { turbo_confirm: "Are you sure?" } }, class: "btn btn-sm btn-danger" %>
        </small>
        <small>
            <%= link_to 'Edit', edit_project_task_path(task.project, task) %>
          <br>
          <small>Assigned to: </small>
          <div class="avatar-group">
            <% task.users.each do |user| %>
              <small>
                <b><%= user.name unless user.nil? %></b>
              </small>
              |
            <% end %>
          </div>
        </small>
      </div>
    </div>
<% end %>